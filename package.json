{
  "name": "@saintno/comfyui-sdk",
  "version": "0.2.52",
  "description": "SDK for ComfyUI",
  "main": "build/index.esm.js",
  "typings": "build/index.d.ts",
  "type": "module",
  "bin": {
    "cfli": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./build/index.esm.js",
      "require": "./build/index.cjs",
      "types": "./build/index.d.ts",
      "default": "./build/index.esm.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tctien342/comfyui-sdk.git"
  },
  "author": "tctien342",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tctien342/comfyui-sdk/issues"
  },
  "homepage": "https://github.com/tctien342/comfyui-sdk#readme",
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.15",
    "@types/ws": "^8.18.1",
    "auto-changelog": "^2.5.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "dts-bundle-generator": "^9.5.1",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "typescript": "^5.5.3"
  },
  "keywords": [
    "comfyui",
    "sdk",
    "typescript",
    "ts",
    "comfy",
    "stable-diffusion",
    "comfyui-api",
    "comfyui-sdk"
  ],
  "dependencies": {
    "@mariozechner/pi-tui": "^0.64.0",
    "ws": "^8.20.0"
  },
  "scripts": {
    "version": "auto-changelog -p",
    "commit": "git-cz",
    "build": "bun build.ts",
    "build:cli": "bun cli/build.ts",
    "build:all": "bun run build && bun run build:cli",
    "cli:dev": "bun cli/bin.ts",
    "test": "bun test",
    "test:cli": "bun test test/cli",
    "test:cli:integration": "COMFYUI_HOST=http://192.168.14.93:8188 bun test test/cli",
    "test:integration": "COMFYUI_HOST=http://192.168.14.93:8188 bun test",
    "format": "prettier --write ."
  },
  "files": [
    "build",
    "dist/cli.js"
  ],
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
